{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "expo-sqlite": ["./node_modules/expo-sqlite"],
      "expo-crypto": ["./node_modules/expo-crypto"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}